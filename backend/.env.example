# Copy this file to .env and fill in your values
# cp .env.example .env

# Flask environment: development | testing | production
FLASK_ENV=development

# Secret keys — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret
JWT_SECRET_KEY=change-me-to-another-random-secret

# Database
# SQLite (default for local dev — no setup needed):
DATABASE_URL=sqlite:///slotwise_dev.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/slotwise

# Anthropic API key for AI slot search (optional — app works without it)
ANTHROPIC_API_KEY=sk-ant-...

# Cancellation window in hours (default: 24)
CANCELLATION_WINDOW_HOURS=24
